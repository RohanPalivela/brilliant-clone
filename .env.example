# Firebase web app config for project "brilliant-clone-5c704".
# Copy to .env.local and paste the values from the Firebase console:
# Project settings -> General -> Your apps -> Web app -> SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI Tutor (optional). Leave blank to run with the tutor disabled — the rest of
# the app is unaffected. Any OpenAI-compatible chat-completions endpoint works
# (OpenAI, OpenRouter, Together, a local proxy, etc.). Paste the key when ready
# to do end-to-end testing.
VITE_AI_TUTOR_API_KEY=
# Defaults to https://api.openai.com/v1 when omitted.
VITE_AI_TUTOR_BASE_URL=
# Defaults to gpt-4o-mini when omitted. For much better instruction-following
# (e.g. the tutor reliably offering review slides without asking permission),
# use a GPT-5 model such as gpt-5.4-mini or gpt-5.4. Reasoning models (gpt-5*,
# o-series) are auto-detected: the client drops `temperature` and sends
# `reasoning_effort: 'low'` to keep replies snappy.
VITE_AI_TUTOR_MODEL=
