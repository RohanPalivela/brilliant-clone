# Firebase web app config for project "brilliant-clone-5c704".
# Copy to .env.local and paste the values from the Firebase console:
# Project settings -> General -> Your apps -> Web app -> SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── AI Tutor · client (safe to bundle) ───────────────────────────────────────
# The browser NEVER sees the model API key. It only calls the /api/tutor proxy.
# Flip this to 'true' to show the tutor UI; leave it off and the rest of the app
# is unaffected.
VITE_AI_TUTOR_ENABLED=false
# Optional: override the proxy path (defaults to /api/tutor).
VITE_AI_TUTOR_ENDPOINT=
# Optional: chat model slug (defaults to gpt-4o-mini). For much better
# instruction-following, use a GPT-5 model such as gpt-5.4-mini. Reasoning models
# (gpt-5*, o-series) are auto-detected: the client drops `temperature` and sends
# `reasoning_effort: 'low'` to keep replies snappy.
VITE_AI_TUTOR_MODEL=

# ── AI Tutor · server (NEVER bundled — no VITE_ prefix) ───────────────────────
# Set these in the Vercel dashboard (Project → Settings → Environment Variables),
# or in a local .env for `vercel dev`. They stay on the edge function.
# The real OpenAI-compatible API key. This is the secret the whole proxy exists
# to protect — it must never get a VITE_ prefix.
AI_TUTOR_API_KEY=
# Optional upstream base url (defaults to https://api.openai.com/v1). Any
# OpenAI-compatible endpoint works (OpenAI, OpenRouter, Together, a local proxy).
AI_TUTOR_BASE_URL=
# Optional: the proxy verifies the learner's ID token against this project id
# before spending credits. If omitted it falls back to VITE_FIREBASE_PROJECT_ID
# (same value, not a secret), so you usually don't need to set this separately.
FIREBASE_PROJECT_ID=
# Set to 'false' to skip ID-token verification (local experimentation only).
TUTOR_REQUIRE_AUTH=
