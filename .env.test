# Loaded by Vite when running in `test` mode (e2e). Points the app at the local
# Firebase Emulator Suite using a demo-* project id, which runs fully offline
# with no real credentials. Never used by production builds.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-brilliant-clone.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-brilliant-clone
VITE_FIREBASE_STORAGE_BUCKET=demo-brilliant-clone.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:demo
VITE_USE_FIREBASE_EMULATOR=true
